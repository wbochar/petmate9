{
  "name": "petmate9",
  "version": "0.9.7",
  "description": "Petmate 9 - a C64 PETSCII graphics editor",
  "private": false,
  "author": "Janne Hellsten <jjhellst@gmail.com>",
  "contributors": [
    {
      "name": "Wolfgang Bochar",
      "email": "wbochar@oni-sys.com",
      "url": "https://wbochar.com/"
    }
  ],
  "license": "MIT",
  "homepage": "./",
  "main": "public/electron.js",
  "keywords": [
    "Graphics, PETSCII, C64, COMMODORE"
  ],
  "scripts": {
    "build": "craco build",
    "start": "concurrently --kill-others \"cross-env BROWSER=none craco start\" \"wait-on http://localhost:3000 && electron .\"",
    "debug": "concurrently --kill-others \"cross-env BROWSER=none craco start\" \"wait-on http://localhost:3000 && electron --remote-debugging-port=9223 .\"",
    "dist-macos": "npx electron-builder --x64 --arm64 --macos --c.extraMetadata.main=build/electron.js -p never",
    "dist-win": "npx electron-builder --x64 --win --c.extraMetadata.main=build/electron.js -p never",
    "dist-linux": "npx electron-builder --x64 --linux --c.extraMetadata.main=build/electron.js -p never",
    "test": "craco test"
  },
  "dependencies": {
    "@craco/craco": "^7.1.0",
    "@electron/remote": "^2.1.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "c64jasm": "^0.9.2",
    "classnames": "^2.5.1",
    "fast-memoize": "^2.5.2",
    "gifenc": "^1.0.3",
    "invariant": "^2.2.4",
    "pngjs": "^3.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^8.1.3",
    "redux": "^4.2.1",
    "redux-logger": "^3.0.6",
    "redux-thunk": "^2.4.2",
    "redux-undo": "^1.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/classnames": "^2.3.4",
    "@types/pngjs": "^3.4.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-redux": "^7.1.34",
    "@types/resize-observer-browser": "^0.1.7",
    "ajv-errors": "^3.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "react-scripts": "5.0.1",
    "sharp": "^0.33.5",
    "strip-ansi": "^6.0.1",
    "typescript": "^5.6.3",
    "version-bump-prompt": "^6.1.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.wbochar.petmate9",
    "compression": "normal",
    "productName": "Petmate 9",
    "afterPack": "./scripts/afterPack.js",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "assets/*"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "type": "distribution",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "icon": "resources/icons",
      "target": [
        "rpm",
        "deb",
        "apk",
        "freebsd",
        "pacman"
      ],
      "description": "Petmate 9",
      "category": "Graphics"
    },
    "fileAssociations": {
      "ext": "petmate",
      "description": "Petmate 9 PETSCII graphics file"
    }
  },
  "overrides": {
    "chokidar": "^3.6.0",
    "nth-check": "^2.0.1",
    "postcss": "^8.4.31",
    "serialize-javascript": "^7.0.3",
    "underscore": "^1.13.8",
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "set-value": "^4.1.0",
    "tar": "^7.5.11"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
